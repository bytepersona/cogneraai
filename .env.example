# Discord (erforderlich)
DISCORD_TOKEN=dein_bot_token

# Anthropic (erforderlich)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Guild-ID für schnelles Syncen der Slash-Commands beim Entwickeln
DISCORD_GUILD_ID=

# Modelle (Standard: Haiku schnell, Sonnet für Fallback / kritische Fälle)
CLAUDE_MODEL_HAIKU=claude-3-haiku-20240307
CLAUDE_MODEL_SONNET=claude-3-5-sonnet-20241022

# Ab dieser Confidence (0-100) wird kein Sonnet-Fallback erzwungen (außer Ban/kritisch)
CONFIDENCE_THRESHOLD=75

# SQLite-Datenbankdatei
DATABASE_PATH=./data/moderation.db

# Logging
LOG_LEVEL=INFO

# Rate-Limit: max. API-Aufrufe pro User & Minute
RATE_LIMIT_PER_USER_PER_MINUTE=8

# Cache: identische Nachrichten (Hash) in Sekunden nicht erneut an API senden
MESSAGE_CACHE_TTL_SECONDS=30

# Kontext: letzte Nachrichten pro Channel
CONTEXT_MESSAGE_COUNT=20

# Warteschlange für on_message → Worker (Backpressure)
MODERATION_QUEUE_MAX=500

# Circuit Breaker bei wiederholten Anthropic-Fehlern
ANTHROPIC_CIRCUIT_FAILURE_THRESHOLD=5
ANTHROPIC_CIRCUIT_RESET_SECONDS=60

# Bot-Hinweise (Mod-Log-, Review-Embeds): nach N Sekunden automatisch löschen (0 = nie)
BOT_MESSAGE_DELETE_AFTER_SECONDS=30

# Optional: VirusTotal — URL-Reputation für „mod-config url-scan“ (Free-Tier mit Limits)
# VIRUSTOTAL_API_KEY=
# VIRUSTOTAL_MALICIOUS_THRESHOLD=1
# VIRUSTOTAL_SUSPICIOUS_THRESHOLD=3

# Optional: Oracle Autonomous (nur vorbereitet; Standard bleibt SQLite)
# USE_ORACLE=false
# ORACLE_USER=
# ORACLE_PASSWORD=
# ORACLE_DSN=
